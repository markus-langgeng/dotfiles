# Control volume
XF86AudioRaiseVolume
    wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 2%+ ; sb-volume 2>/dev/null
XF86AudioLowerVolume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%- ; sb-volume 2>/dev/null
XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ; sb-volume 2>/dev/null
XF86AudioMicMute
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle ; sb-volume 2/dev/null

# Change kb layout
super + space
    sb-kb

# Need the toggle-touchpad and sb-tap scrpt
XF86TouchpadToggle
    toggle-touchpad ; sb-tap

super + F9
    bm-this
super + shift + F9
    open-bm
