# Control volume
XF86AudioRaiseVolume
    wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 2%+
XF86AudioLowerVolume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-
XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
XF86AudioMicMute
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Need the toggle-touchpad
XF86TouchpadToggle
    toggle-touchpad

super + F9
    bm-this
super + shift + F9
    bm-open
Print
    scshot

shift + F12
    setwp

alt + F7
    echo t | tr -d '\n' | xclip -selection c


XF86AudioPrev
    mpc prev
XF86AudioPlay
    mpc toggle
XF86AudioNext
    mpc next
super + F5
    mpc stop


super + alt + {k, b, m, c}
   {kdenlive, $BROWSER, song-player, webcam}

super + alt + {g, r}
   xppen-settings; {gimp, krita}

super + shift + {w, c, g, b}
    firefox {"https://web.whatsapp.com", "https://classroom.google.com", "https://github.com"}

XF86Calculator
    my-calc

# Stop recording
super + shift + Print
    pkill -SIGINT -P $(pgrep record-desktop)
