#!/bin/sh

mkcd() { mkdir -pv "$1" && cd "$1" }
mvcd() { mv -vi "$1" "$2" && cd "$2" }

fcd() {
    local opts=( -not \( -wholename "*/.git" -prune \) -type d )
    case $1 in
        "c" ) cd $(find "$HOME/.config/"    "${opts[@]}" | fzf) ;;
        "sc") cd $(find "$HOME/.local/bin/" "${opts[@]}" | fzf) ;;

        "dl") cd "$HOME/Downloads/" ;;
        "p" ) cd $(find "$HOME/Pictures/"   "${opts[@]}" | fzf) ;;
        "m" ) cd $(find "$HOME/Music/"      "${opts[@]}" | fzf) ;;
        "d" ) cd $(find "$HOME/Documents/"  "${opts[@]}" | fzf) ;;
        *   ) cd $(find ${1:-"$HOME"} "${opts[@]}" >/dev/null 2>&1 | fzf) ;;
    esac
}

open() {
    local opts=( -not \( -wholename "*/.git" -prune \) -type f )
    case $1 in
        "doc") xdg-open $(find "$HOME/Documents/" "${opts[@]}" | fzf) ;;
        "dl" ) xdg-open $(find "$HOME/Downloads/" "${opts[@]}" | fzf) ;;
        "m"  ) xdg-open $(find "$HOME/Music/"     "${opts[@]}" | fzf) ;;
        "p"  ) xdg-open $(find "$HOME/Pictures/"  "${opts[@]}" | fzf) ;;
        *    ) xdg-open $(find ${1:-"$HOME"} "${opts[@]}" >/dev/null 2>&1 | fzf) ;;
    esac
}

getpath() { find ${1:-"$HOME"} -not \( -wholename "*/.git" -prune \) -type f -type f | fzf | tr -d '\n' | xclip -selection c }

