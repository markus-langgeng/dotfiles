#!/bin/sh

mkcd() { mkdir -pv "$1" && cd "$1" || exit; }
mvcd() { mv -vi "$1" "$2" && cd "$2" || exit; }

nobloat_find() {
    find "$1" -not \( -wholename "*/.git" -prune \) \
        -not \( -wholename "*/node_modules" -prune \) \
        -type "$2" 2>/dev/null
}

general_find() {

    while getopts :cbsk:v:w:r:p:d:m: opt; do
        case $opt in
            c ) nobloat_find "$XDG_CONFIG_HOME/"   "${2:-d}" | fzf;;
            b ) nobloat_find "$HOME/.local/bin/"   "${2:-d}" | fzf;;
            s ) nobloat_find "$XDG_DATA_HOME/"     "${2:-d}" | fzf;;

            k )
                case "$OPTARG" in
                    i  ) nobloat_find "$XDG_COLLEGE_DIR"  "${2:-d}" | fimg ;;
                    ii ) nobloat_find "$XDG_COLLEGE_DIR"  "${2:-d}" | grep -iE "^.*\.(png|jpg|jpeg|gif|webp|jfif)$" | fimg ;;
                    ''  ) nobloat_find "$XDG_COLLEGE_DIR"  "${2:-d}" | fzf ;;
                    *  ) nobloat_find "$XDG_COLLEGE_DIR"  "${2:-d}" | fzf ;;
                esac ;;
            v )
                case "$OPTARG" in
                    i  ) nobloat_find "$XDG_PERSONAL_DIR"  "${2:-d}" | fimg ;;
                    ii ) nobloat_find "$XDG_PERSONAL_DIR"  "${2:-d}" | grep -iE "^.*\.(png|jpg|jpeg|gif|webp|jfif)$" | fimg;;
                    *  ) nobloat_find "$XDG_PERSONAL_DIR"  "${2:-d}" | fzf ;;
                esac ;;
            w )
                case "$OPTARG" in
                    i ) nobloat_find "$XDG_WALLPAPERS_DIR"  "${2:-d}" | fimg ;;
                    * ) nobloat_find "$XDG_WALLPAPERS_DIR"  "${2:-d}" | fzf ;;
                esac ;;
            r )
                case "$OPTARG" in
                    i  ) nobloat_find "$HOME/personal/sync/camera/phone/"  "${2:-d}" | fimg;;
                    ii ) nobloat_find "$HOME/personal/sync/camera/phone/"  "${2:-d}" | grep -iE "^.*\.(png|jpg|jpeg|gif|webp|jfif)$" | fimg;;
                    *  ) nobloat_find "$HOME/personal/sync/camera/phone/"  "${2:-d}" | fzf;;
                esac ;;
            p )
                case "$OPTARG" in
                    i  ) nobloat_find "$HOME/personal/sync/media/phone/"  "${2:-d}" | fimg;;
                    ii ) nobloat_find "$HOME/personal/sync/media/phone/"  "${2:-d}" | grep -iE "^.*\.(png|jpg|jpeg|gif|webp|jfif)$" | fimg;;
                    *  ) nobloat_find "$HOME/personal/sync/media/phone/"  "${2:-d}" | fzf;;
                esac ;;
            d )
                case "$OPTARG" in
                    i  ) nobloat_find "$XDG_DOWNLOAD_DIR"  "${2:-d}" | fimg;;
                    ii ) nobloat_find "$XDG_DOWNLOAD_DIR"  "${2:-d}" | grep -iE "^.*\.(png|jpg|jpeg|gif|webp|jfif)$" | fimg;;
                    *  ) nobloat_find "$XDG_DOWNLOAD_DIR"  "${2:-d}" | fzf;;
                esac ;;
            m )
                case "$OPTARG" in
                    i  ) nobloat_find "$XDG_MUSIC_DIR"  "${2:-d}" | fimg;;
                    ii ) nobloat_find "$XDG_MUSIC_DIR"  "${2:-d}" | grep -iE "^.*\.(png|jpg|jpeg|gif|webp|jfif)$" | fimg;;
                    *  ) nobloat_find "$XDG_MUSIC_DIR"  "${2:-d}" | fzf;;
                esac ;;

            * ) echo "Invalid option" ;;
        esac
    done

    shift $((OPTIND -1))
}

fcd() {
    cd "$(general_find "$1" "d")" || return
}

open() {
    xdg-open "$(general_find "${1:-d}" "f" )" 2>/dev/null
}

gfp() {
    general_find "$1" "f" | tr -d '\n' | xclip -selection c
}

gdp() {
    general_find "$1" "d" | tr -d '\n' | xclip -selection c
}

pms() {
    pacman -Ssq "$1" | fzf --multi --preview 'pacman -Si {1}; pacman -Qi {1}' | xargs -ro sudo pacman -S
}

pmr() {
    pacman -Ssq "$1" | fzf --multi --preview 'pacman -Si {1}; pacman -Qi {1}' | xargs -ro sudo pacman -Rns
}

pmq() {
    pacman -Qsq "$1" | fzf --multi --preview 'pacman -Qi {1}; pacman -Qo {1}' | xargs -ro pacman -Qi
}

img_shuf() {
    find . -name '*' -exec file {} \; | grep -o -P '^.+: \w+ image' | awk '{gsub(":",""); print $1}'
}

simple_countdown() {
    for i in $(seq "${1:-10}" -1 1) ; do
        clear ; figlet "$i" ; sleep 1
    done
    clear ; figlet STOP
}

