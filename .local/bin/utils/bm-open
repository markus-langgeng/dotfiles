#!/bin/sh

bmurl=$(sed -E '/(^\s*$|^#)/ d;s/^/[url]    /' "$HOME/.local/share/bookmarks/urls")
bmdir=$(sed -E '/(^\s*$|^#)/ d;s/^/[dir]    /' "$HOME/.local/share/bookmarks/directories")
bmfile=$(sed -E '/(^\s*$|^#)/ d;s/^/[file]    /' "$HOME/.local/share/bookmarks/files")
choice=$(printf "%s\n%s\n%s" "$bmurl" "$bmdir" "$bmfile" | dmenu -i -l 10 -p "Open bookmark:")

[ -z "$choice" ] && exit
echo "$choice" | awk '{print $3}' | tr -d '\n' | xclip -selection c
xdg-open "$(echo "$choice" | awk '{print $3}')"
